@model IEnumerable<HTQL_DU_LICH.Models.Review>

@{
    ViewData["Title"] = "Đánh giá của tôi";
}

<div class="container-fluid">
    <div class="mb-4">
        <h2 class="fw-bold">
            ⭐ Đánh giá của tôi
        </h2>
        <p class="text-muted">
            Xem lại các đánh giá bạn đã gửi cho các dịch vụ du lịch
        </p>
    </div>
    <div class="card shadow border-0">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0">
                📝 Danh sách đánh giá
            </h5>
        </div>
        <div class="card-body">
            @if (Model != null && Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover align-middle">
                        <thead class="table-dark">
                            <tr>
                                <th width="150">Số sao</th>
                                <th>Nội dung đánh giá</th>
                                <th width="220">Ngày tạo</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td>
                                        @if (item.Rating == 5)
                                        {
                                            <span class="badge bg-success fs-6">
                                                ⭐⭐⭐⭐⭐
                                            </span>
                                        }
                                        else if (item.Rating == 4)
                                        {
                                            <span class="badge bg-primary fs-6">
                                                ⭐⭐⭐⭐
                                            </span>
                                        }
                                        else if (item.Rating == 3)
                                        {
                                            <span class="badge bg-warning text-dark fs-6">
                                                ⭐⭐⭐
                                            </span>
                                        }
                                        else if (item.Rating == 2)
                                        {
                                            <span class="badge bg-danger fs-6">
                                                ⭐⭐
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger fs-6">
                                                ⭐
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @item.Comment
                                    </td>
                                    <td>
                                        <span class="badge bg-info text-dark">
                                            📅 @item.CreatedAt.ToString("dd/MM/yyyy HH:mm")
                                        </span>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-warning mb-0">
                    Bạn chưa có đánh giá nào.
                </div>
            }
        </div>
    </div>
</div>