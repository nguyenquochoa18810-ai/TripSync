<!DOCTYPE html>
<html lang="vi">

<head>
    <meta charset="utf-8" />
    <meta name="viewport"
          content="width=device-width, initial-scale=1.0" />

    <title>@ViewData["Title"] - HTQL_DU_LICH</title>

    <link rel="stylesheet"
          href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <link rel="stylesheet"
          href="~/css/site.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="~/HTQL_DU_LICH.styles.css"
          asp-append-version="true" />

    <link rel="stylesheet"
          href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css" />
</head>

<body class="bg-light">

    <header>

        <nav class="navbar navbar-expand-lg navbar-dark bg-primary shadow-sm">

    <div class="container">

                <a class="navbar-brand fw-bold"
                   asp-controller="Home"
                   asp-action="Index">

                    🌍 HTQL DU LỊCH

                </a>

                <button class="navbar-toggler"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#mainNav">

                    <span class="navbar-toggler-icon"></span>

                </button>

                <div class="collapse navbar-collapse"
                     id="mainNav">

                    <ul class="navbar-nav mx-auto">

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Dashboard"
                               asp-action="Index">
                                <i class="fa fa-chart-line"></i>
                                Dashboard
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Trip"
                               asp-action="Index">
                                <i class="fa fa-people-group"></i>
                                Nhóm du lịch
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Expense"
                               asp-action="Index">
                                <i class="fa fa-wallet"></i>
                                Chi phí
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Booking"
                               asp-action="Index">
                                <i class="fa fa-ticket"></i>
                                Đặt dịch vụ
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Review"
                               asp-action="Index">
                                <i class="fa fa-star"></i>
                                Đánh giá
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Notification"
                               asp-action="Index">
                                <i class="fa fa-bell"></i>
                                Thông báo
                            </a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link"
                               asp-controller="Profile"
                               asp-action="Index">
                                <i class="fa fa-user"></i>
                                Hồ sơ
                            </a>
                        </li>

                    </ul>

                </div>

            </div>

        </nav>

    </header>

    <div class="container mt-4">

        <main role="main" class="pb-4">

            @RenderBody()

        </main>

    </div>

    <footer class="bg-white border-top py-3 mt-4">

        <div class="container text-center text-muted">

            &copy; 2026 - HTQL_DU_LICH | Hệ thống quản lý du lịch

        </div>

    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="~/js/site.js"
            asp-append-version="true"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>