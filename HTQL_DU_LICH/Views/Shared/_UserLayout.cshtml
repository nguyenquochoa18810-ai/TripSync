@using Microsoft.AspNetCore.Identity
@using HTQL_DU_LICH.Models
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>TripSync User</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <!-- ========================================== -->
    <!-- CÁC THƯ VIỆN VÀ STYLE ĐƯỢC THÊM VÀO ĐÂY -->
    <!-- ========================================== -->
    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet">

    <style>
        body {
        font-family: 'Inter', sans-serif;
        background: #f5f7fb;
        }

        /* ĐOẠN STYLE ĐƯỢC THÊM VÀO ĐÂY */
        .sidebar {
        width: 260px;
        min-height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        z-index: 1000; /* Thêm z-index để sidebar không bị đè */
        }

        .main-content {
        margin-left: 260px;
        width: calc(100% - 260px); /* Đảm bảo content không bị tràn ngang */
        }
    </style>
    <!-- ========================================== -->
</head>
<body>

    <div class="d-flex">

        <!-- ========================================== -->
        <!-- SIDEBAR MỚI -->
        <!-- ========================================== -->
        <!-- Đã sửa lỗi cú pháp và thêm class 'sidebar' -->
        <div class="sidebar bg-white shadow-sm">

            <div class="p-4">
                <h2 class="fw-bold text-primary">
                    TripSync
                </h2>
                <small>
                    Group Travel Hub
                </small>
            </div>

            <hr />

            <div class="list-group list-group-flush">
                <a asp-controller="Dashboard"
                   asp-action="Index"
                   class="list-group-item">
                    Dashboard
                </a>

                <a asp-controller="Trip"
                   asp-action="MyTrips"
                   class="list-group-item">
                    Nhóm du lịch
                </a>

                <a asp-controller="Matching"
                   asp-action="Index"
                   class="list-group-item">
                    Ghép nhóm
                </a>

                <a asp-controller="ExploreService"
                   asp-action="Index"
                   class="list-group-item">
                    Dịch vụ
                </a>

                <a asp-controller="Expense"
                   asp-action="Index"
                   class="list-group-item">
                    Chi phí
                </a>

                <a asp-controller="MyBooking"
                   asp-action="Index"
                   class="list-group-item">
                    Booking của tôi
                </a>

                <a asp-controller="Review"
                   asp-action="Index"
                   class="list-group-item">
                    Đánh giá
                </a>

                <a asp-controller="Notification"
                   asp-action="Index"
                   class="list-group-item">

                    Thông báo

                    @if (ViewBag.UnreadCount != null &&
                         (int)ViewBag.UnreadCount > 0)
                    {
                        <span class="badge bg-danger">
                            @ViewBag.UnreadCount
                        </span>
                    }

                </a>

                <a asp-controller="Profile"
                   asp-action="Index"
                   class="list-group-item">
                    Hồ sơ
                </a>
                <a asp-controller="Profile"
                   asp-action="Interests"
                   class="list-group-item">
                    Sở thích
                </a>

                

                

                
            </div>
        </div>

        <!-- CONTENT -->
        <!-- Thêm class 'main-content' vào đây -->
        <div class="main-content container-fluid p-4">

            <!-- ========================================== -->
            <!-- HEADER MỚI TRONG VÙNG CONTENT -->
            <!-- ========================================== -->
            <div class="bg-white shadow-sm p-3 mb-4">
                <div class="d-flex justify-content-between">
                    <h4>
                        Dashboard
                    </h4>
                    <div>

                        Xin chào
                        <strong>
                            @User.Identity?.Name
                        </strong>

                        <form asp-area="Identity"
                              asp-page="/Account/Logout"
                              method="post"
                              class="d-inline">

                            <button type="submit"
                                    class="btn btn-danger btn-sm ms-2">
                                Đăng xuất
                            </button>

                        </form>

                    </div>
                </div>
            </div>

            <!-- NỘI DUNG RENDER BODY -->
            @RenderBody()

        </div>

    </div>
</body>
</html>