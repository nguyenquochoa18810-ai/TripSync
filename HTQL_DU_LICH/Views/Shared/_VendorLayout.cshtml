<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>TripSync Vendor</title>

    <link rel="stylesheet"
          href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />

    <style>
            body {
                background: #f5f7fb;
            }

            .sidebar {
                width: 260px;
                min-height: 100vh;
                position: fixed;
                left: 0;
                top: 0;
            }

            .main-content {
                margin-left: 260px;
                width: calc(100% - 260px);
            }
    </style>
</head>
<body>

    <div class="d-flex">

        <div class="sidebar bg-primary text-white p-3">

            <h3>Vendor Panel</h3>

            <hr />

            <ul class="nav flex-column">

                <li class="nav-item">
                    <a class="nav-link text-white"
                       asp-controller="VendorDashboard"
                       asp-action="Index">

                        Dashboard

                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                       asp-controller="VendorService"
                       asp-action="Index">

                        Quản lý dịch vụ

                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                       asp-controller="VendorBooking"
                       asp-action="Index">

                        Quản lý Booking

                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                       asp-controller="Review"
                       asp-action="Index">

                        Đánh giá khách hàng

                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link text-white"
                       asp-controller="VendorProfile"
                       asp-action="Index">

                        Hồ sơ doanh nghiệp

                    </a>
                </li>

            </ul>

            <hr />

            <form asp-area="Identity"
                  asp-page="/Account/Logout"
                  method="post">

                <button type="submit"
                        class="btn btn-danger w-100">

                    Đăng xuất

                </button>

            </form>

        </div>

        <div class="main-content p-4">

            @RenderBody()

        </div>

    </div>

</body>
</html>