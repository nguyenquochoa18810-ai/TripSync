@model IEnumerable<HTQL_DU_LICH.Models.Service>

@{
    ViewData["Title"] = "Danh sách dịch vụ";
}

<h1>Danh sách dịch vụ</h1>

<p>
    <a asp-action="Create" class="btn btn-primary">Tạo mới dịch vụ</a>
</p>

<table class="table">
    <thead>
        <tr>
            <!-- ĐÃ ĐỔI TIÊU ĐỀ SANG TIẾNG VIỆT -->
            <th>Nhà cung cấp</th>
            <th>Tên dịch vụ</th>
            <th>Loại dịch vụ</th>
            <th>Mô tả</th>
            <th>Giá</th>
            <th>Trạng thái</th>
            <th>Hành động</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>
                    @Html.DisplayFor(modelItem => item.VendorId)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Name)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.ServiceType)
                </td>
                <td>
                    @Html.DisplayFor(modelItem => item.Description)
                </td>
                <td>
                    @string.Format("{0:N0} VNĐ", item.Price)
                </td>
                <!-- ĐÃ CẬP NHẬT HIỂN THỊ TRẠNG THÁI -->
                <td>
                    @(item.IsActive ? "Đang hoạt động" : "Ngừng hoạt động")
                </td>
                <td>

                    <a asp-action="Edit"
                       asp-route-id="@item.Id">
                        Sửa
                    </a>

                    |

                    <a asp-action="Details"
                       asp-route-id="@item.Id">
                        Chi tiết
                    </a>

                    |

                    <a asp-action="Delete"
                       asp-route-id="@item.Id">
                        Xóa
                    </a>

                    <br />

                    <a asp-controller="Review"
                       asp-action="Summary"
                       asp-route-serviceId="@item.Id"
                       class="btn btn-info btn-sm mt-1">

                        Thống kê đánh giá

                    </a>

                </td>
            </tr>
        }
    </tbody>
</table>