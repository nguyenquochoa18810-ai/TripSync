@model HTQL_DU_LICH.Models.Service

@{
    ViewData["Title"] = "Delete";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-7">
            <div class="card shadow-sm border-danger">
                <div class="card-header bg-danger text-white">
                    <h4 class="mb-0">Xác nhận xóa Service</h4>
                </div>
                <div class="card-body">
                    <div class="alert alert-warning">
                        Bạn có chắc chắn muốn xóa Service này không?
                    </div>
                    <dl class="row">
                        <dt class="col-sm-4">Vendor ID</dt>
                        <dd class="col-sm-8">@Model.VendorId</dd>
                        <dt class="col-sm-4">Tên Service</dt>
                        <dd class="col-sm-8">@Model.Name</dd>
                        <dt class="col-sm-4">Loại dịch vụ</dt>
                        <dd class="col-sm-8">@Model.ServiceType</dd>
                        <dt class="col-sm-4">Mô tả</dt>
                        <dd class="col-sm-8">@Model.Description</dd>
                        <dt class="col-sm-4">Giá</dt>
                        <dd class="col-sm-8 text-danger fw-bold">
                            @string.Format("{0:N0} VNĐ", Model.Price)
                        </dd>
                    </dl>
                    <form asp-action="Delete">
                        <input type="hidden" asp-for="Id" />
                        <div class="d-flex justify-content-between">
                            <a asp-action="Index"
                               class="btn btn-outline-secondary">
                                ← Hủy
                            </a>
                            <button type="submit"
                                    class="btn btn-danger">
                                Xóa vĩnh viễn
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>