@model List<HTQL_DU_LICH.Models.Notification>

<h2>Thông báo</h2>

<a asp-action="MarkAllRead"
   class="btn btn-success mb-3">
    Đánh dấu tất cả đã đọc
</a>

<table class="table table-bordered">

    <tr>
        <th>Tiêu đề</th>
        <th>Nội dung</th>
        <th>Thời gian</th>
        <th>Trạng thái</th>
        <th>Hành động</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>

            <td>@item.Title</td>

            <td>@item.Content</td>

            <td>
                @item.CreatedAt
            </td>

            <td>

                @if (item.IsRead)
                {
                    <span class="badge bg-success">
                        Đã đọc
                    </span>
                }
                else
                {
                    <span class="badge bg-danger">
                        Chưa đọc
                    </span>
                }

            </td>

            <td>

                @if (!item.IsRead)
                {
                    <a asp-action="MarkAsRead"
                       asp-route-id="@item.Id"
                       class="btn btn-primary btn-sm">

                        Đánh dấu đã đọc

                    </a>
                }

            </td>

        </tr>
    }

</table>