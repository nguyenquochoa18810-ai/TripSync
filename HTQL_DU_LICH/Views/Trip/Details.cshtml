@model HTQL_DU_LICH.Models.TripGroup

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "Chi tiết chuyến đi";
}

<div class="container mt-4">
    <div id="chat"
         class="card shadow-sm mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0">@Model.Title</h4>
                <small class="text-muted">@Model.Destination</small>
            </div>
            <div class="text-end">
                <div class="text-muted">
                    Current User:
                    <b>@User.Identity?.Name</b>
                </div>
                @if ((bool)ViewBag.IsMember &&
    !(bool)ViewBag.IsLeader)
    {
    <a asp-action="Leave"
       asp-route-id="@Model.Id"
       class="btn btn-warning btn-sm mt-1">
        Rời nhóm
    </a>
    }
            </div>
        </div>
    </div>
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-warning">
            @TempData["Message"]
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success">
            @TempData["Success"]
        </div>
    }
    
    @if (ViewBag.Leader?.Id !=
        User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
    {
        @if (!(bool)ViewBag.IsMember)
        {
            <form asp-action="Join"
                  asp-route-id="@Model.Id"
                  method="post">
                <button class="btn btn-success">
                    Gửi yêu cầu tham gia
                </button>
            </form>
            <hr />
        }
    }
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5>Thông tin chuyến đi</h5>
                    <p>
                        <b>Ngày đi:</b>
                        @Model.StartDate.ToShortDateString()
                    </p>
                    <p>
                        <b>Ngày về:</b>
                        @Model.EndDate.ToShortDateString()
                    </p>
                    <p>
                        <b>Ngân sách:</b>
                        @Model.Budget.ToString("N0") VNĐ
                    </p>
                    <p>
                        <b>Mô tả:</b>
                        @Model.Description
                    </p>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>Trưởng nhóm</h5>
                    @if (ViewBag.Leader != null)
                    {
                        <p class="mb-2">
                            <b>
                                @(string.IsNullOrEmpty(ViewBag.Leader.FullName)
                                    ? ViewBag.Leader.Email
                                    : ViewBag.Leader.FullName)
                            </b>
                            <br />
                            <small>
                                @ViewBag.Leader.Email
                            </small>
                        </p>
                        @if (ViewBag.Leader.Id ==
                            User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                        {
                            <a asp-action="Delete"
                               asp-route-id="@Model.Id"
                               class="btn btn-danger btn-sm">
                                Xóa nhóm
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5>
                        Thành viên (@ViewBag.Members.Count)
                    </h5>
                    <table class="table table-sm">
                        @foreach (var member in ViewBag.Members)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(member.AvatarUrl))
                                    {
                                        <img src="@member.AvatarUrl"
                                             width="40"
                                             height="40"
                                             class="rounded-circle" />
                                    }
                                </td>
                                <td>
                                    @(string.IsNullOrEmpty(member.FullName)
                                        ? member.Email
                                        : member.FullName)
                                </td>
                                <td>
                                    @member.Email
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>

    @if ((bool)ViewBag.IsMember || (bool)ViewBag.IsLeader)
    {
    <div class="card shadow-sm mb-3">
        <div class="card-header">
            <b>Chat nhóm</b>
        </div>


        <div class="card-body">
            <div id="chatBox"
                 class="border rounded p-3 mb-3"
                 style="height:300px;overflow-y:auto;background:#fafafa">
                @if (ViewBag.Messages != null)
                {
                    foreach (var msg in ViewBag.Messages)
                    {
                        <div class="mb-2">
                            <b>@msg.UserName</b>
                            <small class="text-muted">
                                (@msg.Time)
                            </small>
                            <br />
                            @msg.Message
                        </div>
                    }
                }
            </div>
            <form id="chatForm">

                <input type="hidden"
                       id="tripId"
                       name="tripId"
                       value="@Model.Id" />
                <div class="input-group">
                   <input id="messageInput"
                    name="message"
                    class="form-control"
                    placeholder="Nhập tin nhắn..." />
                    <button type="button"
                            id="sendBtn"
                            class="btn btn-primary">
                        Gửi
                    </button>
                </div>
            </form>
        </div>
    </div>
    

    @if (ViewBag.UnpaidMembers != null
    && ViewBag.UnpaidMembers.Count > 0)
{
    <div class="card shadow-sm mb-3">
        <div class="card-header bg-warning">
            Thành viên chưa thanh toán
        </div>

        <div class="card-body">

            <table class="table">

                <thead>
                    <tr>
                        <th>Email</th>
                        <th>Số tiền</th>
                    </tr>
                </thead>

                <tbody>

                    @foreach (var item in ViewBag.UnpaidMembers)
                    {
                        <tr>
                            <td>@item.Email</td>

                            <td>
                                @item.Amount.ToString("N0")
                                VNĐ
                            </td>
                        </tr>
                    }

                </tbody>

            </table>

        </div>
    </div>
}
    
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between">
            <b>Chi phí</b>

       

            <a asp-controller="Expense"
               asp-action="Create"
               asp-route-tripId="@Model.Id"
               class="btn btn-success btn-sm">
                + Thêm chi phí
            </a>
        </div>
        <div class="card-body">
            <table class="table">
                @foreach (var expense in ViewBag.Expenses)
                {
                    <tr>
                        <td>@expense.Title</td>
                        <td>
                            @expense.Amount.ToString("N0") VNĐ
                        </td>
                    </tr>
                }
            </table>
            <h5 class="text-end">
                Tổng:
                @(((decimal)ViewBag.TotalExpense).ToString("N0"))
                VNĐ
            </h5>
        </div>
    </div>

    }
    @if ((bool)ViewBag.IsLeader)
    {

        <form asp-action="CompleteTrip"
              method="post"
              class="mt-2">

            <input id="completeTripId"
                   name="tripId"
                   value="@Model.Id"
                   type="hidden" />

            <button class="btn btn-success">
                Hoàn thành chuyến đi
            </button>

        </form>
        <a asp-controller="JoinRequest"
           asp-action="Manage"
           asp-route-tripId="@Model.Id"
           class="btn btn-warning">
            Quản lý yêu cầu tham gia
        </a>
        <a asp-action="Delete"
           asp-route-id="@Model.Id"
           class="btn btn-danger mt-2">
            Xóa nhóm
        </a>

       
      
    }
</div>
<script>

    window.onload = function () {

        var box =
            document.getElementById("chatBox");

        if (box) {
            box.scrollTop = box.scrollHeight;
        }
    };

    document
    .getElementById("sendBtn")
    .addEventListener("click", async function () {

        let tripId =
            document.getElementById("tripId").value;

        let message =
            document.getElementById("messageInput").value;

        if (message.trim() === "")
            return;

        const response =
            await fetch("/Trip/SendMessage", {

                method: "POST",

                headers: {
                    "Content-Type":
                        "application/x-www-form-urlencoded"
                },

                body:
                    "tripId=" + tripId +
                    "&message=" +
                    encodeURIComponent(message)
            });

        const data =
            await response.json();

        console.log(data);

        if (data.success) {

            let chatBox =
                document.getElementById("chatBox");

            let div =
                document.createElement("div");

            div.className = "mb-2";

            div.innerHTML =
                "<b>" + data.userName + "</b> " +
                "<small class='text-muted'>(" +
                data.time +
                ")</small><br/>" +
                data.message;

            chatBox.appendChild(div);

            document
                .getElementById("messageInput")
                .value = "";

            chatBox.scrollTop =
                chatBox.scrollHeight;
        }
    });

</script>