@model HTQL_DU_LICH.Models.TripGroup

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "Chi tiết chuyến đi";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0">@Model.Title</h4>
                <small class="text-muted">@Model.Destination</small>
            </div>
            <div class="text-end">
                <div class="text-muted">
                    Current User:
                    <b>@User.Identity?.Name</b>
                </div>
                @if (!(bool)ViewBag.IsLeader)
                {
                    <a asp-action="Leave"
                       asp-route-id="@Model.Id"
                       class="btn btn-warning btn-sm mt-1">
                        Rời nhóm
                    </a>
                }
            </div>
        </div>
    </div>
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-warning">
            @TempData["Message"]
        </div>
    }
    @if (ViewBag.Leader?.Id !=
        User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
    {
        @if (!(bool)ViewBag.IsMember)
        {
            <form asp-action="Join"
                  asp-route-id="@Model.Id"
                  method="post">
                <button class="btn btn-success">
                    Gửi yêu cầu tham gia
                </button>
            </form>
            <hr />
        }
    }
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5>Thông tin chuyến đi</h5>
                    <p>
                        <b>Ngày đi:</b>
                        @Model.StartDate.ToShortDateString()
                    </p>
                    <p>
                        <b>Ngày về:</b>
                        @Model.EndDate.ToShortDateString()
                    </p>
                    <p>
                        <b>Ngân sách:</b>
                        @Model.Budget.ToString("N0") VNĐ
                    </p>
                    <p>
                        <b>Mô tả:</b>
                        @Model.Description
                    </p>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>Trưởng nhóm</h5>
                    @if (ViewBag.Leader != null)
                    {
                        <p class="mb-2">
                            <b>
                                @(string.IsNullOrEmpty(ViewBag.Leader.FullName)
                                    ? ViewBag.Leader.Email
                                    : ViewBag.Leader.FullName)
                            </b>
                            <br />
                            <small>
                                @ViewBag.Leader.Email
                            </small>
                        </p>
                        @if (ViewBag.Leader.Id ==
                            User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                        {
                            <a asp-action="Delete"
                               asp-route-id="@Model.Id"
                               class="btn btn-danger btn-sm">
                                Xóa nhóm
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5>
                        Thành viên (@ViewBag.Members.Count)
                    </h5>
                    <table class="table table-sm">
                        @foreach (var member in ViewBag.Members)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(member.AvatarUrl))
                                    {
                                        <img src="@member.AvatarUrl"
                                             width="40"
                                             height="40"
                                             class="rounded-circle" />
                                    }
                                </td>
                                <td>
                                    @(string.IsNullOrEmpty(member.FullName)
                                        ? member.Email
                                        : member.FullName)
                                </td>
                                <td>
                                    @member.Email
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow-sm mb-3">
        <div class="card-header">
            <b>Chat nhóm</b>
        </div>
        <div class="card-body">
            <div id="chatBox"
                 class="border rounded p-3 mb-3"
                 style="height:300px;overflow-y:auto;background:#fafafa">
                @if (ViewBag.Messages != null)
                {
                    foreach (var msg in ViewBag.Messages)
                    {
                        <div class="mb-2">
                            <b>@msg.UserName</b>
                            <small class="text-muted">
                                (@msg.Time)
                            </small>
                            <br />
                            @msg.Message
                        </div>
                    }
                }
            </div>
            <form asp-action="SendMessage" method="post">
                <input type="hidden"
                       name="tripId"
                       value="@Model.Id" />
                <div class="input-group">
                    <input name="message"
                           class="form-control"
                           placeholder="Nhập tin nhắn..." />
                    <button class="btn btn-primary">
                        Gửi
                    </button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="card shadow-sm mb-3">
        <div class="card-header">
            <b>Yêu cầu dịch vụ</b>
        </div>
        <div class="card-body table-responsive">
            <table class="table">
                @foreach (var item in ViewBag.ServiceRequests)
                {
                    if (item.Status == "Approved")
                    {
                        <tr>
                            <td>
                                @item.ServiceName
                            </td>
                            <td colspan="2">
                                <span class="badge bg-success">
                                    Đã xác nhận
                                </span>
                            </td>
                        </tr>
                        continue;
                    }
                    var yes =
                    ((List<HTQL_DU_LICH.Models.ServiceRequestVote>)
                    ViewBag.ServiceVotes)
                    .Count(x =>
                        x.ServiceRequestId == item.Id &&
                        x.IsApproved);
                    var no =
                    ((List<HTQL_DU_LICH.Models.ServiceRequestVote>)
                    ViewBag.ServiceVotes)
                    .Count(x =>
                        x.ServiceRequestId == item.Id &&
                        !x.IsApproved);
                    string currentUserId =
                    User.FindFirst(
                        System.Security.Claims.ClaimTypes.NameIdentifier
                    )?.Value;
                    bool voted =
                    ((List<HTQL_DU_LICH.Models.ServiceRequestVote>)
                    ViewBag.ServiceVotes)
                    .Any(x =>
                        x.ServiceRequestId == item.Id &&
                        x.UserId == currentUserId);
                    <tr>
                        <td>
                            @item.ServiceName
                        </td>
                        <td>
                            👍 @yes | 👎 @no
                        </td>
                        <td>
                            @if (!voted)
                            {
                                <form asp-action="ApproveService"
                                      method="post">
                                    <input type="hidden"
                                           name="requestId"
                                           value="@item.Id" />
                                    <button class="btn btn-success btn-sm">
                                        Đồng ý
                                    </button>
                                </form>
                                <form asp-action="RejectService"
                                      method="post">
                                    <input type="hidden"
                                           name="requestId"
                                           value="@item.Id" />
                                    <button class="btn btn-danger btn-sm">
                                        Từ chối
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Đã bỏ phiếu
                                </span>
                            }
                        </td>
                    </tr>
                }
            </table>
        </div>
    </div>
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between">
            <b>Chi phí</b>
            <a asp-controller="Expense"
               asp-action="Create"
               asp-route-tripId="@Model.Id"
               class="btn btn-success btn-sm">
                + Thêm chi phí
            </a>
        </div>
        <div class="card-body">
            <table class="table">
                @foreach (var expense in ViewBag.Expenses)
                {
                    <tr>
                        <td>@expense.Title</td>
                        <td>
                            @expense.Amount.ToString("N0") VNĐ
                        </td>
                    </tr>
                }
            </table>
            <h5 class="text-end">
                Tổng:
                @(((decimal)ViewBag.TotalExpense).ToString("N0"))
                VNĐ
            </h5>
        </div>
    </div>
    @if ((bool)ViewBag.IsLeader)
    {
        <a asp-controller="JoinRequest"
           asp-action="Manage"
           asp-route-tripId="@Model.Id"
           class="btn btn-warning">
            Quản lý yêu cầu tham gia
        </a>
        <a asp-action="Delete"
           asp-route-id="@Model.Id"
           class="btn btn-danger mt-2">
            Xóa nhóm
        </a>
    }
</div>
<script>
    window.onload = function () {
        var box = document.getElementById("chatBox");
        if (box)
            box.scrollTop = box.scrollHeight;
    }
</script>