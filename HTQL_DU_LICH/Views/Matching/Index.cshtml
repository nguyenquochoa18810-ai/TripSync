@model List<HTQL_DU_LICH.ViewModels.MatchResultViewModel>

<h2>Ghép nhóm du lịch</h2>

<table class="table table-bordered">
    <tr>
        <th>Nhóm</th>
        <th>Sở thích</th>
        <th>Độ phù hợp</th>
        <th>Số thành viên</th>
        <th>Trạng thái</th>
        <th>Hành động</th>
    </tr>

    @foreach (var item in Model)
    {
        <tr>
            <td>@item.TripTitle</td>

            <td>

                @foreach (var interest in item.Interests)
                {
                    <span class="badge bg-secondary">
                        @interest
                    </span>
                }

            </td>

            <td>

                <strong>
                    @item.MatchPercent %
                </strong>

                <br />

                <small>
                    (@item.CommonInterestCount/@item.TotalTripInterestCount sở thích khớp)
                </small>

            </td>

            <td>
                @item.MemberCount người
            </td>

            <td>
                @if (item.Status == "Trưởng nhóm")
                {
                    <span class="badge bg-success">
                        Trưởng nhóm
                    </span>
                }
                else if (item.Status == "Đã tham gia")
                {
                    <span class="badge bg-primary">
                        Đã tham gia
                    </span>
                }
                else if (item.Status == "Chờ duyệt")
                {
                    <span class="badge bg-warning">
                        Chờ duyệt
                    </span>
                }
                else
                {
                    <span class="badge bg-secondary">
                        Chưa tham gia
                    </span>
                }
            </td>

            <td>

                <a asp-controller="Trip"
                   asp-action="Details"
                   asp-route-id="@item.TripId"
                   class="btn btn-info btn-sm">
                    Xem nhóm
                </a>

                @if (item.Status == "Chưa tham gia")
                {
                    <form asp-controller="Trip"
                          asp-action="Join"
                          asp-route-id="@item.TripId"
                          method="post"
                          style="display:inline;">

                        <button class="btn btn-success btn-sm">
                            Tham gia
                        </button>

                    </form>
                }

            </td>
        </tr>
    }
</table>