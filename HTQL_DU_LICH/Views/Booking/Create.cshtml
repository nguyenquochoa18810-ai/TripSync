@model HTQL_DU_LICH.Models.Booking
@using HTQL_DU_LICH.Models

@{
    ViewData["Title"] = "Đặt dịch vụ";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        📅 Đặt dịch vụ
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                Chọn nhóm du lịch
                            </label>
                            <select asp-for="TripGroupId"
                                    class="form-select">
                                @foreach (var trip in (List<TripGroup>)ViewBag.Trips)
                                {
                                    <option value="@trip.Id">
                                        @trip.Title
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                Chọn dịch vụ
                            </label>
                            <select asp-for="ServiceId"
                                    class="form-select">
                                @foreach (var service in (List<Service>)ViewBag.Services)
                                {
                                    <option value="@service.Id">
                                        @service.Name
                                    </option>
                                }
                            </select>
                        </div>
                        <div class="d-flex justify-content-end gap-2">
                            <a asp-action="Index"
                               class="btn btn-secondary">
                                ← Quay lại
                            </a>
                            <button type="submit"
                                    class="btn btn-success">
                                ✔ Đặt chỗ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>