@model HTQL_DU_LICH.ViewModels.DashboardViewModel

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "Dashboard";
}

<style>
    .dashboard-card {
        border-radius: 16px;
        transition: all .2s ease;
    }

        .dashboard-card:hover {
            transform: translateY(-4px);
        }

    .icon-box {
        width: 55px;
        height: 55px;
        border-radius: 14px;
        display: flex;
        justify-content: center;
        align-items: center;
        color: white;
        font-size: 22px;
    }
</style>

<div class="d-flex justify-content-between align-items-center mb-4">

    <div>
        <h2 class="fw-bold">
            👋 Xin chào, @User.Identity?.Name
        </h2>

        <p class="text-muted mb-0">
            Chúc bạn có những chuyến đi thật tuyệt vời!
        </p>
    </div>

    <div>
        <a asp-controller="Trip"
           asp-action="Create"
           class="btn btn-primary">

            ➕ Tạo chuyến đi

        </a>
    </div>

</div>

<div class="row g-4">

    <div class="col-lg-3 col-md-6">

        <div class="card dashboard-card border-0 shadow">

            <div class="card-body">

                <div class="d-flex justify-content-between">

                    <div>

                        <small class="text-muted">
                            Chuyến đi gần nhất
                        </small>

                        <h5 class="fw-bold mt-2">
                            @(Model.LatestTripName ?? "Chưa có")
                        </h5>

                    </div>

                    <div class="icon-box bg-primary">
                        ✈️
                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="card dashboard-card border-0 shadow">

            <div class="card-body">

                <div class="d-flex justify-content-between">

                    <div>

                        <small class="text-muted">
                            Booking gần nhất
                        </small>

                        <h5 class="fw-bold mt-2">
                            @(Model.LatestBookingService ?? "Chưa có")
                        </h5>

                    </div>

                    <div class="icon-box bg-success">
                        🏨
                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="card dashboard-card border-0 shadow">

            <div class="card-body">

                <div class="d-flex justify-content-between">

                    <div>

                        <small class="text-muted">
                            Công nợ
                        </small>

                        <h5 class="fw-bold mt-2 text-danger">
                            @Model.MyDebt.ToString("N0") VNĐ
                        </h5>

                    </div>

                    <div class="icon-box bg-warning">
                        💰
                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="col-lg-3 col-md-6">

        <div class="card dashboard-card border-0 shadow">

            <div class="card-body">

                <div class="d-flex justify-content-between">

                    <div>

                        <small class="text-muted">
                            Thông báo
                        </small>

                        <h5 class="fw-bold mt-2">
                            @Model.TotalNotifications
                        </h5>

                    </div>

                    <div class="icon-box bg-danger">
                        🔔
                    </div>

                </div>

            </div>

        </div>

    </div>

</div>

<div class="row mt-4">

    <div class="col-lg-8">

        <div class="card border-0 shadow">

            <div class="card-header bg-white">

                <h5 class="mb-0">
                    🔥 Dịch vụ được đánh giá cao
                </h5>

            </div>

            <div class="card-body">

                <table class="table table-hover align-middle">

                    <thead>

                        <tr>
                            <th>Dịch vụ</th>
                            <th>Điểm</th>
                            <th>Lượt đánh giá</th>
                        </tr>

                    </thead>

                    <tbody>

                        @if (ViewBag.TopServices != null)
                        {
                            foreach (var item in ViewBag.TopServices)
                            {
                                <tr>

                                    <td>
                                        <strong>
                                            @item.ServiceName
                                        </strong>
                                    </td>

                                    <td>
                                        ⭐ @item.AverageRating.ToString("0.0")
                                    </td>

                                    <td>
                                        @item.TotalReviews
                                    </td>

                                </tr>
                            }
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="col-lg-4">

        <div class="card border-0 shadow">

            <div class="card-header bg-white">

                <h5 class="mb-0">
                    🚀 Truy cập nhanh
                </h5>

            </div>

            <div class="card-body d-grid gap-2">

                <a asp-controller="Trip"
                   asp-action="MyTrips"
                   class="btn btn-outline-primary">

                    ✈️ Nhóm du lịch

                </a>

                <a asp-controller="Expense"
                   asp-action="Index"
                   class="btn btn-outline-success">

                    💰 Chi phí

                </a>

                <a asp-controller="MyBooking"
                   asp-action="Index"
                   class="btn btn-outline-warning">

                    🏨 Booking của tôi

                </a>

                <a asp-controller="Notification"
                   asp-action="Index"
                   class="btn btn-outline-danger">

                    🔔 Thông báo

                </a>

            </div>

        </div>

    </div>

</div>