@model List<HTQL_DU_LICH.ViewModels.ExpenseListViewModel>

@{
    ViewData["Title"] = "Quản lý chi phí";
}

<div class="container-fluid">

    <div class="d-flex justify-content-between align-items-center mb-4">

        <h2 class="fw-bold">
            💰 Quản lý chi phí
        </h2>

        <div>

            <a asp-action="Summary"
               class="btn btn-primary">

                📊 Tổng quan tài chính

            </a>

            <a asp-action="Debts"
               class="btn btn-warning">

                💳 Công nợ

            </a>

            <a asp-action="Transactions"
               class="btn btn-info text-white">

                📜 Lịch sử giao dịch

            </a>

        </div>

    </div>

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">
                Danh sách chi phí
            </h5>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>
                            <th>Nhóm</th>
                            <th>Tiêu đề</th>
                            <th>Số tiền</th>
                            <th>Người trả</th>
                            <th>Trạng thái</th>
                            <th>Tiến độ</th>
                            <th width="220">Hành động</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model)
                        {
                            <tr>

                                <td>
                                    <strong>@item.TripName</strong>
                                </td>

                                <td>
                                    @item.Title
                                </td>

                                <td class="fw-bold text-danger">
                                    @item.Amount.ToString("N0") VNĐ
                                </td>

                                <td>
                                    @item.PaidBy
                                </td>

                                <td>

                                    @if (item.IsApproved)
                                    {
                                        <span class="badge bg-success">
                                            ✔ Đã xác nhận
                                        </span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-warning text-dark">
                                            ⏳ Chờ xác nhận
                                        </span>
                                    }

                                </td>

                                <td>

                                    @{
                                        double percent = 0;

                                        if (item.TotalApprovals > 0)
                                        {
                                            percent =
                                            (double)item.ApprovedCount
                                            / item.TotalApprovals * 100;
                                        }
                                    }

                                    <div class="progress">

                                        <div class="progress-bar bg-success"
                                             style="width:@percent%">

                                            @item.ApprovedCount/@item.TotalApprovals

                                        </div>

                                    </div>

                                </td>

                                <td>

                                    <a asp-controller="Expense"
                                       asp-action="ExpenseDetails"
                                       asp-route-id="@item.Id"
                                       class="btn btn-info btn-sm text-white">

                                        🔍 Chi tiết

                                    </a>

                                    @if (!item.IsApproved && item.CanApprove)
                                    {
                                        <form asp-controller="Expense"
                                              asp-action="ApproveExpense"
                                              method="post"
                                              class="d-inline">

                                            <input type="hidden"
                                                   name="expenseId"
                                                   value="@item.Id" />

                                            <button class="btn btn-success btn-sm">

                                                ✔

                                            </button>

                                        </form>

                                        <form asp-controller="Expense"
                                              asp-action="RejectExpense"
                                              method="post"
                                              class="d-inline">

                                            <input type="hidden"
                                                   name="expenseId"
                                                   value="@item.Id" />

                                            <button class="btn btn-danger btn-sm">

                                                ✖

                                            </button>

                                        </form>
                                    }

                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

</div>