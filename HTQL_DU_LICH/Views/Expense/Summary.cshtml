@model HTQL_DU_LICH.ViewModels.ExpenseSummaryViewModel

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "Tổng quan tài chính";
}

<div class="container-fluid">

    <div class="mb-4">

        <h2 class="fw-bold">
            📊 Tổng quan tài chính
        </h2>

        <p class="text-muted">
            Theo dõi toàn bộ chi phí và công nợ của các chuyến đi
        </p>

    </div>

    <div class="row g-4 mb-4">

        <div class="col-md-4">

            <div class="card dashboard-card shadow border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Tổng chi phí
                            </small>

                            <h3 class="fw-bold text-primary mt-2">
                                @Model.TotalExpense.ToString("N0") VNĐ
                            </h3>

                        </div>

                        <div class="icon-box bg-primary">
                            💰
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card dashboard-card shadow border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Bạn cần thanh toán
                            </small>

                            <h3 class="fw-bold text-danger mt-2">
                                @Model.YouOwe.ToString("N0") VNĐ
                            </h3>

                        </div>

                        <div class="icon-box bg-danger">
                            💳
                        </div>

                    </div>

                </div>

            </div>

        </div>

        <div class="col-md-4">

            <div class="card dashboard-card shadow border-0">

                <div class="card-body">

                    <div class="d-flex justify-content-between">

                        <div>

                            <small class="text-muted">
                                Người khác nợ bạn
                            </small>

                            <h3 class="fw-bold text-success mt-2">
                                @Model.YouAreOwed.ToString("N0") VNĐ
                            </h3>

                        </div>

                        <div class="icon-box bg-success">
                            📈
                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <div class="card shadow border-0">

        <div class="card-header bg-primary text-white">

            <h5 class="mb-0">
                📋 Chi tiết phân chia chi phí
            </h5>

        </div>

        <div class="card-body">

            <div class="table-responsive">

                <table class="table table-hover align-middle">

                    <thead class="table-dark">

                        <tr>
                            <th>Khoản chi</th>
                            <th>Người trả</th>
                            <th>Tổng tiền</th>
                            <th>Số thành viên</th>
                            <th>Phần của bạn</th>
                        </tr>

                    </thead>

                    <tbody>

                        @foreach (var item in Model.DebtDetails)
                        {
                            <tr>

                                <td>
                                    <strong>
                                        @item.ExpenseTitle
                                    </strong>
                                </td>

                                <td>
                                    @item.PaidBy
                                </td>

                                <td class="fw-bold text-danger">
                                    @item.ExpenseAmount.ToString("N0") VNĐ
                                </td>

                                <td>
                                    @item.MemberCount người
                                </td>

                                <td class="fw-bold text-primary">
                                    @item.YourShare.ToString("N0") VNĐ
                                </td>

                            </tr>
                        }

                    </tbody>

                </table>

            </div>

        </div>

    </div>

    <div class="card mt-4 border-0 shadow">

        <div class="card-header bg-info text-white">

            <h5 class="mb-0">
                ℹ Cách tính công nợ
            </h5>

        </div>

        <div class="card-body">

            <p class="mb-0">

                <strong>
                    Công thức:
                </strong>

                <br />

                Phần phải trả = Tổng chi phí ÷ Số thành viên tham gia.

                <br /><br />

                Nếu một thành viên đã thanh toán toàn bộ khoản chi,
                hệ thống sẽ tự động tính số tiền những thành viên khác
                cần hoàn trả cho người đó.

            </p>

        </div>

    </div>

</div>
