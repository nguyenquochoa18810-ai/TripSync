@model HTQL_DU_LICH.Models.TripGroup

@{
    Layout = "~/Views/Shared/_UserLayout.cshtml";
    ViewData["Title"] = "Chi tiết chuyến đi";
}

<div class="container mt-4">
    <div class="card shadow-sm border-0 mb-3">
        <div class="card-body d-flex justify-content-between align-items-center">
            <div>
                <h4 class="mb-0">@Model.Title</h4>
                <small class="text-muted">@Model.Destination</small>
            </div>
            <div class="text-end">
                <div class="text-muted">
                    Current User:
                    <b>@User.Identity?.Name</b>
                </div>
                @if (!(bool)ViewBag.IsLeader)
                {
                    <a asp-action="Leave"
                       asp-route-id="@Model.Id"
                       class="btn btn-warning btn-sm mt-1">
                        Rời nhóm
                    </a>
                }
            </div>
        </div>
    </div>
    @if (TempData["Message"] != null)
    {
        <div class="alert alert-success">
            @TempData["Message"]
        </div>
    }
    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger">
            @TempData["Error"]
        </div>
    }
    @if (Model.IsCompleted)
    {
        <div class="alert alert-secondary">
            ✅ <b>Chuyến đi đã hoàn thành</b>
            @(Model.CompletedAt.HasValue
                ? " (" + Model.CompletedAt.Value.ToString("HH:mm dd/MM/yyyy") + ")"
                : "")
        </div>
    }
    @if (ViewBag.Leader?.Id !=
        User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
    {
        @if (!(bool)ViewBag.IsMember)
        {
            <form asp-action="Join"
                  asp-route-id="@Model.Id"
                  method="post">
                <button class="btn btn-success">
                    Gửi yêu cầu tham gia
                </button>
            </form>
            <hr />
        }
    }
    <div class="row">
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5>Thông tin chuyến đi</h5>
                    <p>
                        <b>Ngày đi:</b>
                        @Model.StartDate.ToShortDateString()
                    </p>
                    <p>
                        <b>Ngày về:</b>
                        @Model.EndDate.ToShortDateString()
                    </p>
                    <p>
                        <b>Ngân sách:</b>
                        @Model.Budget.ToString("N0") VNĐ
                    </p>
                    <p>
                        <b>Mô tả:</b>
                        @Model.Description
                    </p>
                </div>
            </div>
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5>Trưởng nhóm</h5>
                    @if (ViewBag.Leader != null)
                    {
                        <p class="mb-2">
                            <b>
                                @(string.IsNullOrEmpty(ViewBag.Leader.FullName)
                                    ? ViewBag.Leader.Email
                                    : ViewBag.Leader.FullName)
                            </b>
                            <br />
                            <small>
                                @ViewBag.Leader.Email
                            </small>
                        </p>
                        @if (ViewBag.Leader.Id ==
                            User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value)
                        {
                            <a asp-action="Delete"
                               asp-route-id="@Model.Id"
                               class="btn btn-danger btn-sm">
                                Xóa nhóm
                            </a>
                        }
                    }
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card shadow-sm mb-3">
                <div class="card-body">
                    <h5>
                        Thành viên (@ViewBag.Members.Count)
                    </h5>
                    <table class="table table-sm">
                        @foreach (var member in ViewBag.Members)
                        {
                            <tr>
                                <td>
                                    @if (!string.IsNullOrEmpty(member.AvatarUrl))
                                    {
                                        <img src="@member.AvatarUrl"
                                             width="40"
                                             height="40"
                                             class="rounded-circle" />
                                    }
                                </td>
                                <td>
                                    @(string.IsNullOrEmpty(member.FullName)
                                        ? member.Email
                                        : member.FullName)
                                </td>
                                <td>
                                    @member.Email
                                </td>
                            </tr>
                        }
                    </table>
                </div>
            </div>
        </div>
    </div>
    <div class="card shadow-sm mb-3">
        <div class="card-header">
            <b>Chat nhóm</b>
        </div>
        <div class="card-body">
            <div id="chatBox"
                 data-trip-id="@Model.Id"
                 data-current-user="@ViewBag.CurrentUserId"
                 data-send-url="@Url.Action("SendMessage", "Trip")"
                 data-get-url="@Url.Action("GetMessages", "Trip")"
                 class="border rounded p-3 mb-3"
                 style="height:300px;overflow-y:auto;background:#fafafa">
                @if (ViewBag.Messages != null)
                {
                    foreach (var msg in ViewBag.Messages)
                    {
                        bool mine = msg.UserId == ViewBag.CurrentUserId;
                        <div class="mb-2 chat-msg @(mine ? "text-end" : "")"
                             data-msg-id="@msg.Id">
                            <b>@msg.UserName</b>
                            <small class="text-muted">
                                (@msg.Time.ToString("HH:mm dd/MM"))
                            </small>
                            <br />
                            <span class="d-inline-block px-2 py-1 rounded @(mine ? "bg-primary text-white" : "bg-white border")">
                                @msg.Message
                            </span>
                        </div>
                    }
                }
            </div>
            <div class="input-group">
                <input id="chatInput"
                       class="form-control"
                       placeholder="Nhập tin nhắn..."
                       autocomplete="off" />
                <button id="chatSend" class="btn btn-primary" type="button">
                    Gửi
                </button>
            </div>
        </div>
    </div>
    
    <div class="card shadow-sm mb-3">
        <div class="card-header">
            <b>Yêu cầu dịch vụ</b>
        </div>
        <div class="card-body table-responsive">
            <table class="table">
                @foreach (var item in ViewBag.ServiceRequests)
                {
                    if (item.Status == "Approved")
                    {
                        <tr>
                            <td>
                                @item.ServiceName
                            </td>
                            <td colspan="2">
                                <span class="badge bg-success">
                                    Đã xác nhận
                                </span>
                            </td>
                        </tr>
                        continue;
                    }
                    var yes =
                    ((List<HTQL_DU_LICH.Models.ServiceRequestVote>)
                    ViewBag.ServiceVotes)
                    .Count(x =>
                        x.ServiceRequestId == item.Id &&
                        x.IsApproved);
                    var no =
                    ((List<HTQL_DU_LICH.Models.ServiceRequestVote>)
                    ViewBag.ServiceVotes)
                    .Count(x =>
                        x.ServiceRequestId == item.Id &&
                        !x.IsApproved);
                    string currentUserId =
                    User.FindFirst(
                        System.Security.Claims.ClaimTypes.NameIdentifier
                    )?.Value;
                    bool voted =
                    ((List<HTQL_DU_LICH.Models.ServiceRequestVote>)
                    ViewBag.ServiceVotes)
                    .Any(x =>
                        x.ServiceRequestId == item.Id &&
                        x.UserId == currentUserId);
                    <tr>
                        <td>
                            @item.ServiceName
                        </td>
                        <td>
                            👍 @yes | 👎 @no
                        </td>
                        <td>
                            @if (!voted)
                            {
                                <form asp-action="ApproveService"
                                      method="post">
                                    <input type="hidden"
                                           name="requestId"
                                           value="@item.Id" />
                                    <button class="btn btn-success btn-sm">
                                        Đồng ý
                                    </button>
                                </form>
                                <form asp-action="RejectService"
                                      method="post">
                                    <input type="hidden"
                                           name="requestId"
                                           value="@item.Id" />
                                    <button class="btn btn-danger btn-sm">
                                        Từ chối
                                    </button>
                                </form>
                            }
                            else
                            {
                                <span class="badge bg-secondary">
                                    Đã bỏ phiếu
                                </span>
                            }
                        </td>
                    </tr>
                }
            </table>
        </div>
    </div>
    <div class="card shadow-sm mb-3">
        <div class="card-header">
            <b>Dịch vụ áp dụng cho chuyến</b>
        </div>
        <div class="card-body">
            @{
                var appliedServices = ViewBag.AppliedServices as IEnumerable<dynamic>;
                var myOptOuts = ViewBag.MyOptOuts as List<int> ?? new List<int>();
            }
            @if (appliedServices == null || !appliedServices.Any())
            {
                <p class="text-muted mb-0">Chưa có dịch vụ nào được áp dụng.</p>
            }
            else
            {
                <table class="table align-middle mb-0">
                    @foreach (var sv in appliedServices)
                    {
                        bool optedOut = myOptOuts.Contains((int)sv.ServiceId);
                        <tr>
                            <td>
                                @sv.ServiceName
                                @if (optedOut)
                                {
                                    <span class="badge bg-secondary ms-1">
                                        Bạn không dùng
                                    </span>
                                }
                            </td>
                            <td class="text-end">
                                @if ((bool)ViewBag.IsMember && !Model.IsCompleted)
                                {
                                    <form asp-action="ToggleServiceOptOut"
                                          method="post"
                                          class="d-inline">
                                        <input type="hidden" name="tripId" value="@Model.Id" />
                                        <input type="hidden" name="serviceId" value="@sv.ServiceId" />
                                        @if (optedOut)
                                        {
                                            <button class="btn btn-outline-success btn-sm">
                                                Dùng lại dịch vụ này
                                            </button>
                                        }
                                        else
                                        {
                                            <button class="btn btn-outline-secondary btn-sm">
                                                Tôi không dùng dịch vụ này
                                            </button>
                                        }
                                    </form>
                                }
                            </td>
                        </tr>
                    }
                </table>
                <small class="text-muted">
                    Bỏ chọn một dịch vụ thì bạn sẽ không bị chia tiền cho khoản chi tương ứng.
                </small>
            }
        </div>
    </div>
    <div class="card shadow-sm mb-3">
        <div class="card-header d-flex justify-content-between">
            <b>Chi phí</b>
            <a asp-controller="Expense"
               asp-action="Create"
               asp-route-tripId="@Model.Id"
               class="btn btn-success btn-sm">
                + Thêm chi phí
            </a>
        </div>
        <div class="card-body">
            <table class="table">
                @foreach (var expense in ViewBag.Expenses)
                {
                    <tr>
                        <td>@expense.Title</td>
                        <td>
                            @expense.Amount.ToString("N0") VNĐ
                        </td>
                    </tr>
                }
            </table>
            <h5 class="text-end">
                Tổng:
                @(((decimal)ViewBag.TotalExpense).ToString("N0"))
                VNĐ
            </h5>
        </div>
    </div>
    @if ((bool)ViewBag.IsLeader)
    {
        <a asp-controller="JoinRequest"
           asp-action="Manage"
           asp-route-tripId="@Model.Id"
           class="btn btn-warning">
            Quản lý yêu cầu tham gia
        </a>
        @if (!Model.IsCompleted)
        {
            <form asp-action="CompleteTrip"
                  asp-route-id="@Model.Id"
                  method="post"
                  class="d-inline"
                  onsubmit="return confirm('Hoàn thành chuyến đi? Sẽ không thể hoàn thành nếu còn khoản chưa thanh toán.');">
                <button type="submit" class="btn btn-success">
                    ✅ Hoàn thành chuyến đi
                </button>
            </form>
        }
        <a asp-action="Delete"
           asp-route-id="@Model.Id"
           class="btn btn-danger mt-2">
            Xóa nhóm
        </a>
    }
</div>
<script>
    (function () {
        var box = document.getElementById("chatBox");
        if (!box) return;

        var input = document.getElementById("chatInput");
        var sendBtn = document.getElementById("chatSend");

        var tripId = box.getAttribute("data-trip-id");
        var currentUser = box.getAttribute("data-current-user");
        var sendUrl = box.getAttribute("data-send-url");
        var getUrl = box.getAttribute("data-get-url");

        // Id tin nhắn lớn nhất đang hiển thị (để polling chỉ lấy tin mới)
        var lastId = 0;
        box.querySelectorAll(".chat-msg").forEach(function (el) {
            var id = parseInt(el.getAttribute("data-msg-id") || "0", 10);
            if (id > lastId) lastId = id;
        });

        function scrollBottom() {
            box.scrollTop = box.scrollHeight;
        }

        function escapeHtml(s) {
            var d = document.createElement("div");
            d.textContent = s;
            return d.innerHTML;
        }

        function appendMessage(m) {
            if (m.id && m.id <= lastId) return;   // tránh trùng
            var mine = m.userId === currentUser;

            var wrap = document.createElement("div");
            wrap.className = "mb-2 chat-msg" + (mine ? " text-end" : "");
            wrap.setAttribute("data-msg-id", m.id);

            wrap.innerHTML =
                '<b>' + escapeHtml(m.userName) + '</b> ' +
                '<small class="text-muted">(' + escapeHtml(m.time) + ')</small><br/>' +
                '<span class="d-inline-block px-2 py-1 rounded ' +
                (mine ? 'bg-primary text-white' : 'bg-white border') + '">' +
                escapeHtml(m.message) + '</span>';

            box.appendChild(wrap);
            if (m.id > lastId) lastId = m.id;
        }

        function sendMessage() {
            var text = (input.value || "").trim();
            if (!text) return;

            sendBtn.disabled = true;

            var body = new URLSearchParams();
            body.append("tripId", tripId);
            body.append("message", text);

            fetch(sendUrl, {
                method: "POST",
                headers: { "Content-Type": "application/x-www-form-urlencoded" },
                body: body.toString()
            })
            .then(function (r) { return r.json(); })
            .then(function (data) {
                if (data && data.success) {
                    appendMessage(data);
                    scrollBottom();
                    input.value = "";
                }
            })
            .catch(function () { })
            .finally(function () {
                sendBtn.disabled = false;
                input.focus();
            });
        }

        function pollMessages() {
            fetch(getUrl + "?tripId=" + tripId + "&afterId=" + lastId)
                .then(function (r) { return r.json(); })
                .then(function (list) {
                    if (Array.isArray(list) && list.length) {
                        list.forEach(appendMessage);
                        scrollBottom();
                    }
                })
                .catch(function () { });
        }

        sendBtn.addEventListener("click", sendMessage);
        input.addEventListener("keydown", function (e) {
            if (e.key === "Enter") {
                e.preventDefault();   // chặn submit form -> không reload
                sendMessage();
            }
        });

        scrollBottom();
        setInterval(pollMessages, 3000);   // lấy tin mới mỗi 3s
    })();
</script>