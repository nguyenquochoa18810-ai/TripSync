@model HTQL_DU_LICH.Models.Vendor

@{
    ViewData["Title"] = "Xóa nhà cung cấp";
}

<div class="container mt-4">

    <div class="row justify-content-center">

        <div class="col-md-8 col-lg-6">

            <div class="card shadow-sm border-danger">

                <div class="card-header bg-danger text-white">

                    <h5 class="mb-0">
                        ⚠ Xác nhận xóa nhà cung cấp
                    </h5>

                </div>

                <div class="card-body">

                    <div class="alert alert-warning">

                        Bạn có chắc chắn muốn xóa nhà cung cấp này không?
                        Hành động này không thể hoàn tác.

                    </div>

                    <div class="mb-3">

                        <h5 class="mb-1">
                            @Model.CompanyName
                        </h5>

                        <small class="text-muted">
                            User ID: @Model.UserId
                        </small>

                    </div>

                    <hr />

                    <dl class="row">

                        <dt class="col-sm-4">
                            Mô tả
                        </dt>

                        <dd class="col-sm-8">
                            @Model.Description
                        </dd>

                        <dt class="col-sm-4">
                            Số điện thoại
                        </dt>

                        <dd class="col-sm-8">
                            @Model.Phone
                        </dd>

                        <dt class="col-sm-4">
                            Email
                        </dt>

                        <dd class="col-sm-8">
                            @Model.Email
                        </dd>

                        <dt class="col-sm-4">
                            Địa chỉ
                        </dt>

                        <dd class="col-sm-8">
                            @Model.Address
                        </dd>

                        <dt class="col-sm-4">
                            Trạng thái
                        </dt>

                        <dd class="col-sm-8">

                            @if (Model.IsApproved)
                            {
                                <span class="badge bg-success">
                                    Đã duyệt
                                </span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">
                                    Chưa duyệt
                                </span>
                            }

                        </dd>

                    </dl>

                    <form asp-action="Delete"
                          method="post"
                          class="mt-3">

                        <input type="hidden"
                               asp-for="Id" />

                        <div class="d-flex justify-content-between">

                            <a asp-action="Index"
                               class="btn btn-outline-secondary">

                                ← Hủy

                            </a>

                            <button type="submit"
                                    class="btn btn-danger">

                                Xóa vĩnh viễn

                            </button>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>