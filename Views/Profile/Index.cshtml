@model HTQL_DU_LICH.Models.ApplicationUser

@{
    bool profileCompleted =
        ViewBag.IsProfileCompleted ?? false;

    ViewData["Title"] = "Hồ sơ cá nhân";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        👤 Hồ sơ cá nhân
                    </h3>
                </div>
                <div class="card-body p-4">
                    @if (ViewBag.Success != null)
                    {
                        <div class="alert alert-success">
                            ✅ @ViewBag.Success
                        </div>
                    }
                    <div class="text-center mb-4">
                        @if (!string.IsNullOrEmpty(Model.AvatarUrl))
                        {
                            <img src="@Model.AvatarUrl"
                                 width="160"
                                 height="160"
                                 class="rounded-circle shadow profile-avatar" />
                        }
                        else
                        {
                            <img src="/images/default-avatar.png"
                                 width="160"
                                 height="160"
                                 class="rounded-circle shadow profile-avatar" />
                        }
                        <h3 class="mt-3">
                            @(string.IsNullOrEmpty(Model.FullName)
                                ? "Người dùng"
                                : Model.FullName)
                        </h3>
                        <p class="text-muted">
                            @Model.Email
                        </p>
                    </div>
                    <hr />
                    <h5 class="mb-3">
                        📸 Cập nhật ảnh đại diện
                    </h5>
                    <form asp-action="UploadAvatar"
                          method="post"
                          enctype="multipart/form-data">
                        <div class="input-group mb-3">
                            <input type="file"
                                   name="AvatarFile"
                                   class="form-control" />
                            <button type="submit"
                                    class="btn btn-success">
                                Upload Avatar
                            </button>
                        </div>
                    </form>
                    <hr />
                    <h5 class="mb-3">
                        📝 Thông tin cá nhân
                    </h5>
                    <form method="post">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Họ tên
                            </label>
                            <input asp-for="FullName"
                                   id="FullName"
                                   class="form-control"
                                   readonly="@profileCompleted" />
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                Giới thiệu
                            </label>
                            <textarea asp-for="Bio"
                                      id="Bio"
                                      class="form-control"
                                      readonly="@profileCompleted">
                            </textarea>
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit"
                                    id="btnSave"
                                    class="btn btn-primary"
                                    disabled="@profileCompleted">
                                💾 Lưu thông tin
                            </button>
                            <button type="button"
                                    id="btnEdit"
                                    class="btn btn-warning">

                                ✏️ Chỉnh sửa hồ sơ

                            </button>
                        </div>

                        @section Scripts
                        {
                            <script>

                                                        document
                                                            .getElementById("btnEdit")
                                                            ?.addEventListener("click", function ()
                                                            {
                                                                document
                                                                    .getElementById("FullName")
                                                                    .removeAttribute("readonly");

                                                                document
                                                                    .getElementById("Bio")
                                                                    .removeAttribute("readonly");

                                                                document
                                                                    .getElementById("btnSave")
                                                                    .removeAttribute("disabled");
                                                            });

                            </script>
                        }
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>