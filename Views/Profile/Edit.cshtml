@model HTQL_DU_LICH.ViewModels.ProfileEditViewModel

@{
    ViewData["Title"] = "Chỉnh sửa hồ sơ";
}

<div class="container">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow border-0">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        ✏️ Chỉnh sửa hồ sơ
                    </h3>
                </div>
                <div class="card-body p-4">
                    <form asp-action="Edit"
                          method="post"
                          enctype="multipart/form-data">
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Họ tên
                            </label>
                            <input type="text"
                                   name="FullName"
                                   value="@Model.FullName"
                                   class="form-control" />
                        </div>
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                Tiểu sử
                            </label>
                            <textarea name="Bio"
                                      rows="5"
                                      class="form-control">@Model.Bio</textarea>
                        </div>
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                Ảnh đại diện
                            </label>
                            <input type="file"
                                   name="AvatarFile"
                                   class="form-control" />
                        </div>
                        <div class="d-flex gap-2">
                            <button type="submit"
                                    class="btn btn-success">
                                💾 Lưu thay đổi
                            </button>
                            <a asp-action="Index"
                               class="btn btn-secondary">
                                ↩ Quay lại
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>