@using Microsoft.AspNetCore.Identity
@using HTQL_DU_LICH.Models
@inject UserManager<ApplicationUser> UserManager

<!DOCTYPE html>
<html>

<head>
    <meta charset="utf-8" />
    <title>TripSync User</title>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" />
    <script src="https://cdn.tailwindcss.com"></script>

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap"
          rel="stylesheet">

    <style>
        body {
        font-family: 'Inter', sans-serif;
        background: #f5f7fb;
        }

        .sidebar {
        width: 260px;
        min-height: 100vh;
        position: fixed;
        left: 0;
        top: 0;
        z-index: 1000;
        }

        .main-content {
        margin-left: 260px;
        width: calc(100% - 260px);
        }

        /* ===== NAV ITEM STYLE PRO ===== */
        .menu-item {
        display: flex;
        align-items: center;
        padding: 10px 16px;
        margin: 4px 10px;
        border-radius: 10px;
        color: #333;
        text-decoration: none;
        transition: 0.2s;
        font-weight: 500;
        }

        .menu-item:hover {
        background: #eef3ff;
        color: #0d6efd;
        }

        .menu-item.active {
        background: #0d6efd;
        color: #fff;
        }

        .menu-item .badge {
        margin-left: auto;
        }
    </style>
</head>

<body>

    <div class="d-flex">

        <!-- SIDEBAR -->
        <div class="sidebar bg-white shadow-sm">

            <div class="p-4">
                <h2 class="fw-bold text-primary mb-0">TripSync</h2>
                <small class="text-muted">Group Travel Hub</small>
            </div>

            <hr class="mx-3" />

            <div class="px-2">

                <a asp-controller="Dashboard" asp-action="Index"
                   class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Dashboard" ? "active" : "")">
                    🏠 Dashboard
                </a>

                <a asp-controller="Trip" asp-action="MyTrips"
                   class="menu-item @(ViewContext.RouteData.Values["Controller"]?.ToString() == "Trip" ? "active" : "")">
                    👥 Nhóm du lịch
                </a>

                <a asp-controller="Matching" asp-action="Index"
                   class="menu-item">
                    🤝 Ghép nhóm
                </a>

                <a asp-controller="ExploreService" asp-action="Index"
                   class="menu-item">
                    🧳 Dịch vụ
                </a>

                <a asp-controller="Expense" asp-action="Index"
                   class="menu-item">
                    💰 Chi phí
                </a>

                <a asp-controller="MyBooking" asp-action="Index"
                   class="menu-item">
                    🎫 Booking
                </a>

                <a asp-controller="Review" asp-action="Index"
                   class="menu-item">
                    ⭐ Đánh giá
                </a>

                <a asp-controller="Notification" asp-action="Index"
                   class="menu-item">

                    🔔 Thông báo

                    @if (ViewBag.UnreadCount != null)
                    {
                        int unread = Convert.ToInt32(ViewBag.UnreadCount);

                        if (unread > 0)
                        {
                            <span class="badge bg-danger">
                                @unread
                            </span>
                        }
                    }

                </a>

                <a asp-controller="Profile" asp-action="Index"
                   class="menu-item">
                    👤 Hồ sơ
                </a>

                <a asp-controller="Profile" asp-action="Interests"
                   class="menu-item">
                    ❤️ Sở thích
                </a>

            </div>

        </div>

        <!-- CONTENT -->
        <div class="main-content container-fluid p-4">

            <!-- HEADER -->
            <div class="bg-white shadow-sm rounded-3 p-3 mb-4">

                <div class="d-flex justify-content-between align-items-center">

                    <h5 class="mb-0 fw-bold text-secondary">

                        @(ViewData["Title"] ?? "TripSync")

                    </h5>

                    <div class="d-flex align-items-center">

                        <span class="me-2 text-muted">
                            Xin chào,
                        </span>

                        <strong class="me-3">
                            @User.Identity?.Name
                        </strong>

                        <form asp-area="Identity"
                              asp-page="/Account/Logout"
                              method="post"
                              class="d-inline">

                            <button type="submit"
                                    class="btn btn-outline-danger btn-sm">
                                Đăng xuất
                            </button>

                        </form>

                    </div>

                </div>

            </div>

            <!-- BODY -->
            @RenderBody()

        </div>

    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>